{
  "manifest_version": 3,
  "name": "B站分P时长统计",
  "version": "1.7",
  "description": "B站分P视频时长统计",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}